# ============================================
# 数据库配置（必需）
# ============================================
DATABASE_URL="postgresql://postgres:password@localhost:5432/ai_recruitment_app"

# ============================================
# Better Auth 配置（生产环境必需）
# ============================================
# 生成方式: openssl rand -base64 32
BETTER_AUTH_SECRET="dev-secret-change-me-in-production"

# ============================================
# Google OAuth（生产环境必需，如需 Google 登录）
# ============================================
BETTER_AUTH_GOOGLE_CLIENT_ID=""
BETTER_AUTH_GOOGLE_CLIENT_SECRET=""
# 或使用通用命名
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ============================================
# GitHub OAuth（可选，如需 GitHub 登录）
# ============================================
BETTER_AUTH_GITHUB_CLIENT_ID=""
BETTER_AUTH_GITHUB_CLIENT_SECRET=""
# 或使用通用命名
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# ============================================
# Anthropic Claude API（必需，用于 AI 功能）
# ============================================
CLAUDE_API_KEY=""

# ============================================
# GitHub Token（可选，用于提高 API 限制）
# ============================================
GITHUB_TOKEN=""

# ============================================
# Node 环境
# ============================================
NODE_ENV="development"

# ============================================
# 跳过环境变量验证（仅用于 Docker 构建）
# ============================================
# SKIP_ENV_VALIDATION="1"

